<script>
"use strict";
var S={name:'',level:0,totalScore:0,gamesPlayed:0,sfx:true,vibrate:true,fx:true,leaderboard:[],usedQs:{},subject:'',subjectName:'',subjectIcon:'',qs:[],qi:0,score:0,hints:3,answered:false,hintShown:false,selected:-1,timeLeft:30,maxTime:30,timer:null,roomCode:'',battleSubject:''};
function save(){try{localStorage.setItem('nq6',JSON.stringify({n:S.name,l:S.level,ts:S.totalScore,gp:S.gamesPlayed,sf:S.sfx,vb:S.vibrate,fx:S.fx,lb:S.leaderboard}))}catch(e){}}
function load(){try{var d=JSON.parse(localStorage.getItem('nq6'));if(d){S.name=d.n||'';S.level=d.l||0;S.totalScore=d.ts||0;S.gamesPlayed=d.gp||0;if(d.sf!==undefined)S.sfx=d.sf;if(d.vb!==undefined)S.vibrate=d.vb;if(d.fx!==undefined)S.fx=d.fx;if(d.lb)S.leaderboard=d.lb}}catch(e){}}

var audioCtx=null;
function getAudio(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();return audioCtx}
function playTone(freq,dur,type,vol){if(!S.sfx)return;try{var c=getAudio(),o=c.createOscillator(),g=c.createGain();o.type=type||'sine';o.frequency.value=freq;g.gain.setValueAtTime(vol||.1,c.currentTime);g.gain.exponentialRampToValueAtTime(.001,c.currentTime+(dur||.15));o.connect(g);g.connect(c.destination);o.start();o.stop(c.currentTime+(dur||.15))}catch(e){}}
function sfxCorrect(){playTone(523,.08);setTimeout(function(){playTone(659,.08)},80);setTimeout(function(){playTone(784,.15)},160)}
function sfxWrong(){playTone(200,.2,'square',.08);setTimeout(function(){playTone(150,.25,'square',.06)},120)}
function sfxClick(){playTone(800,.04,'sine',.05)}
function sfxTick(){playTone(1000,.02,'sine',.03)}
function sfxFinish(){playTone(523,.1);setTimeout(function(){playTone(659,.1)},100);setTimeout(function(){playTone(784,.1)},200);setTimeout(function(){playTone(1047,.2)},300)}
function vib(ms){if(S.vibrate&&navigator.vibrate)navigator.vibrate(ms||30)}

function spawnConfetti(n){if(!S.fx)return;var colors=['#a855f7','#f59e0b','#10b981','#3b82f6','#ef4444','#ec4899','#06b6d4'];for(var i=0;i<(n||60);i++){var el=document.createElement('div');el.className='confetti-piece';var shapes=['■','●','▲','★','◆'];el.textContent=shapes[Math.floor(Math.random()*5)];el.style.cssText='left:'+Math.random()*100+'vw;color:'+colors[i%colors.length]+';font-size:'+(8+Math.random()*8)+'px;animation-duration:'+(2+Math.random()*3)+'s;animation-delay:'+Math.random()*.5+'s;opacity:'+(0.6+Math.random()*0.4);document.body.appendChild(el);setTimeout(function(e){return function(){e.remove()}}(el),6000)}}

function showScreen(id){var screens=document.querySelectorAll('.screen');for(var i=0;i<screens.length;i++)screens[i].classList.remove('active');document.getElementById(id).classList.add('active');if(id==='home')renderHome();if(id==='leaderboard')renderLeaderboard();if(id==='settings')renderSettings();if(id==='battle')renderBattle();sfxClick()}

var selectedLevel=0;
function selectAge(lv){selectedLevel=lv;sfxClick();var btns=document.querySelectorAll('.age-btn');for(var i=0;i<btns.length;i++)btns[i].classList.remove('selected');document.getElementById('age'+lv).classList.add('selected');checkReg()}
function checkReg(){var ok=document.getElementById('regName').value.trim()&&selectedLevel>0;var btn=document.getElementById('regBtn');btn.style.opacity=ok?'1':'.5';btn.style.pointerEvents=ok?'auto':'none'}
function doRegister(){S.name=document.getElementById('regName').value.trim();S.level=selectedLevel;save();showScreen('home')}
document.getElementById('regName').addEventListener('input',checkReg);

var SUBJECTS=[{key:'math',name:'رياضيات',icon:'🧮',desc:'حساب، جبر، هندسة'},{key:'physics',name:'فيزياء',icon:'⚛️',desc:'قوى، طاقة، حركة'},{key:'finance',name:'تمويل ومالية',icon:'💰',desc:'خصومات، فوائد، استثمار'},{key:'stats',name:'إحصاء واحتمالات',icon:'📊',desc:'متوسطات، توزيعات'},{key:'flight',name:'طيران وفضاء',icon:'✈️',desc:'ديناميكا هوائية'},{key:'iq',name:'ذكاء وتفكير',icon:'🧩',desc:'أنماط، منطق، ألغاز'}];

function renderHome(){var ub=document.getElementById('homeUserBar');var ln=['','المستوى الأول (9-11)','المستوى الثاني (12-14)','المستوى الثالث (15-18)'];ub.innerHTML='<div class="user-avatar">'+(S.name?S.name[0]:'?')+'</div><div style="flex:1"><div style="font-size:14px;font-weight:700">'+S.name+'</div><div style="font-size:11px;color:var(--txt3)">'+(ln[S.level]||'')+'</div></div><div class="icon-btn" onclick="showScreen(\'leaderboard\')">🏆</div><div class="icon-btn" onclick="showScreen(\'settings\')" style="margin-right:6px">⚙️</div>';var grid=document.getElementById('topicGrid');var html='';for(var i=0;i<SUBJECTS.length;i++){var s=SUBJECTS[i];var cnt=QB.generate(s.key,S.level).length;html+='<div class="topic-card" onclick="startQuiz(\''+s.key+'\',\''+s.name+'\',\''+s.icon+'\')"><div class="topic-icon">'+s.icon+'</div><div class="topic-name">'+s.name+'</div><div class="topic-desc">'+s.desc+'</div><div class="chip chip-lav" style="margin-top:6px">'+cnt+'+ سؤال</div></div>'}grid.innerHTML=html}

function shuffle(a){for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t}return a}
function ri(a,b){return a+Math.floor(Math.random()*(b-a+1))}

function startQuiz(key,name,icon,count,isBattle){sfxClick();S.subject=key;S.subjectName=name;S.subjectIcon=icon;var allQs=QB.generate(key,S.level);var fresh=[];for(var i=0;i<allQs.length;i++){if(!S.usedQs[allQs[i].text])fresh.push(allQs[i])}var c=count||15;var pool=fresh.length>=c?fresh:allQs;shuffle(pool);S.qs=pool.slice(0,c);for(var i=0;i<S.qs.length;i++)S.usedQs[S.qs[i].text]=1;S.qi=0;S.score=0;S.hints=3;S.answered=false;S.hintShown=false;S.selected=-1;S.maxTime=isBattle?20:30;showScreen('quiz');renderQuestion()}

function renderQuestion(){if(S.qi>=S.qs.length){finishQuiz();return}S.answered=false;S.hintShown=false;S.selected=-1;var q=S.qs[S.qi];document.getElementById('quizTitle').textContent=S.subjectIcon+' '+S.subjectName;document.getElementById('quizCount').textContent=(S.qi+1)+'/'+S.qs.length;document.getElementById('quizProgress').style.width=((S.qi+1)/S.qs.length*100)+'%';var labels=['أ','ب','ج','د'];var h='<div style="display:flex;gap:6px;margin-bottom:12px"><span class="chip chip-lav">'+q.type+'</span><span class="chip chip-gold">'+['','9-11','12-14','15-18'][S.level]+'</span></div><div style="font-size:19px;font-weight:900;line-height:2;margin-bottom:16px;color:#fff;background:rgba(10,1,24,.85);padding:16px;border-radius:12px;border:1px solid rgba(168,85,247,.2)" id="qText">'+q.text+'</div>';for(var i=0;i<q.options.length;i++){h+='<div class="opt" id="opt'+i+'" onclick="answer('+i+')"><div class="opt-label" id="optL'+i+'">'+labels[i]+'</div><div class="opt-text">'+q.options[i]+'</div><div class="opt-icon" id="optI'+i+'"></div></div>'}if(S.hints>0){var hintText=q.hint||('الإجابة الصحيحة تبدأ بـ: '+q.options[q.ans].substring(0,Math.min(3,q.options[q.ans].length))+'...');h+='<div style="text-align:center;margin-top:8px;padding:8px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.12);border-radius:10px" id="hintBtn"><span style="cursor:pointer;color:var(--gold);font-size:14px;font-weight:700" onclick="useHint()">💡 استخدم تلميح ('+S.hints+' متبقي)</span></div>'}h+='<div id="hintBox"></div><div id="feedbackBox"></div>';h+='<div class="stats-row"><div class="stat-chip" style="background:rgba(16,185,129,.1);color:var(--green)">✅ '+S.score+'</div><div class="stat-chip" style="background:rgba(239,68,68,.1);color:var(--red)">❌ '+(S.qi-S.score)+'</div><div class="stat-chip" style="background:rgba(245,158,11,.1);color:var(--gold)">💡 '+S.hints+'</div></div>';document.getElementById('quizBody').innerHTML=h;startTimer()}

function startTimer(){clearInterval(S.timer);S.timeLeft=S.maxTime;updateTimer();S.timer=setInterval(function(){S.timeLeft--;updateTimer();if(S.timeLeft<=5)sfxTick();if(S.timeLeft<=0){clearInterval(S.timer);autoAnswer()}},1000)}
function updateTimer(){var el=document.getElementById('quizTimer');var bar=document.getElementById('timerBar');var pct=S.timeLeft/S.maxTime;var color=S.timeLeft>10?'var(--green)':S.timeLeft>5?'var(--gold)':'var(--red)';el.innerHTML='⏱ '+S.timeLeft+' ثانية';el.style.color=color;bar.style.width=(pct*100)+'%';bar.style.background=color;if(S.timeLeft<=5){el.style.animation='timerPulse .5s ease-in-out'}else{el.style.animation='none'}}
function autoAnswer(){if(!S.answered){S.answered=true;showFeedback(-1);vib(200)}}

function answer(idx){if(S.answered)return;clearInterval(S.timer);S.answered=true;S.selected=idx;var q=S.qs[S.qi];if(idx===q.ans)S.score++;if(FB.roomRef)fbUpdateScore(S.score,false);showFeedback(idx)}

function showFeedback(idx){var q=S.qs[S.qi];for(var i=0;i<q.options.length;i++){var el=document.getElementById('opt'+i);var ic=document.getElementById('optI'+i);if(i===q.ans){el.classList.add('correct');ic.textContent='✓'}else if(i===idx&&idx!==q.ans){el.classList.add('wrong');ic.textContent='✗'}else{el.classList.add('dimmed')}}if(idx===q.ans){sfxCorrect();vib(30);spawnConfetti(15)}else{sfxWrong();vib(100);var qt=document.getElementById('qText');if(qt)qt.style.animation='shake .4s'}var isC=idx===q.ans;var fb=document.getElementById('feedbackBox');var cColor=isC?'var(--green)':'var(--red)';fb.innerHTML='<div class="feedback '+(isC?'correct':'wrong')+'" style="margin-top:12px"><div style="font-size:36px">'+(isC?'🎉':'😔')+'</div><div style="font-size:16px;font-weight:800;color:'+cColor+';margin-top:4px">'+(isC?'إجابة صحيحة! أحسنت':'إجابة خاطئة')+'</div>'+(!isC?'<div style="font-size:14px;color:var(--txt2);margin-top:4px">الإجابة: '+q.options[q.ans]+'</div>':'')+'</div><button class="btn btn-primary" style="margin-top:12px" onclick="nextQuestion()">'+(S.qi+1>=S.qs.length?'📊 النتائج':'← السؤال التالي')+'</button>';var hb=document.getElementById('hintBtn');if(hb)hb.style.display='none'}

