l="#fde68a"/><circle cx="131" cy="126" r="2" fill="#1e1050"/><circle cx="139" cy="126" r="2" fill="#1e1050"/><path d="M132 132 Q135 135 138 132" stroke="#1e1050" stroke-width="1.5" fill="none"/><rect x="127" y="115" width="16" height="4" rx="2" fill="#60a5fa"/><polygon points="100,15 106,28 120,28 109,37 113,50 100,42 87,50 91,37 80,28 94,28" fill="#f59e0b"/><polygon points="100,15 104,24 112,24 106,30 108,38 100,33 92,38 94,30 88,24 96,24" fill="#fde68a"/><rect x="82" y="96" width="36" height="18" rx="6" fill="#1e1050" stroke="#a855f7" stroke-width="2"/><text x="100" y="110" font-size="13" fill="#fff" text-anchor="middle" font-weight="bold" font-family="sans-serif">VS</text><line x1="60" y1="96" x2="82" y2="105" stroke="#c084fc" stroke-width="1.5" opacity=".4"/><line x1="140" y1="96" x2="118" y2="105" stroke="#fbbf24" stroke-width="1.5" opacity=".4"/><line x1="76" y1="135" x2="88" y2="114" stroke="#34d399" stroke-width="1.5" opacity=".4"/><line x1="124" y1="135" x2="112" y2="114" stroke="#60a5fa" stroke-width="1.5" opacity=".4"/></svg></div>
