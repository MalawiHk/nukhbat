<title>نُخبة العقول</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#06010f;--bg2:#0e0524;--card:#150a38;--card2:#1e1050;
--lav:#a855f7;--lav2:#7c3aed;--lav3:#c084fc;--lavbg:rgba(168,85,247,.1);
--gold:#f59e0b;--goldL:#fde68a;--green:#10b981;--red:#ef4444;--blue:#3b82f6;
--txt:#fff;--txt2:#ddd0ff;--txt3:#a090d0;
--font:'Tajawal',system-ui,-apple-system,sans-serif;--radius:16px;--rSm:12px
}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--txt);font-family:var(--font);-ms-overflow-style:none;scrollbar-width:none}
html::-webkit-scrollbar,body::-webkit-scrollbar{display:none;width:0}
body{display:flex;flex-direction:column}

.screen{display:none;flex-direction:column;height:100%;overflow-y:auto;overflow-x:hidden;position:relative}
.screen.active{display:flex}
.screen::-webkit-scrollbar{display:none;width:0}
.screen{-ms-overflow-style:none;scrollbar-width:none}

.bg-stars{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.bg-stars::before,.bg-stars::after{content:'';position:absolute;border-radius:50%;filter:blur(80px);opacity:.15}
.bg-stars::before{width:400px;height:400px;background:var(--lav2);top:-100px;right:-100px;animation:floatOrb 12s ease-in-out infinite}
.bg-stars::after{width:300px;height:300px;background:var(--gold);bottom:-50px;left:-100px;animation:floatOrb 15s ease-in-out infinite reverse}
@keyframes floatOrb{0%,100%{transform:translate(0,0)}50%{transform:translate(40px,30px)}}

.grad-text{background:linear-gradient(135deg,var(--lav3),var(--goldL));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

.btn{border:none;border-radius:var(--rSm);padding:14px 24px;font-family:var(--font);font-weight:800;font-size:16px;cursor:pointer;-webkit-transition:all .2s;transition:all .2s;display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;-webkit-justify-content:center;justify-content:center;gap:8px;width:100%;position:relative;overflow:hidden}
.btn-primary{background:linear-gradient(135deg,var(--lav2),#4f46e5);color:#fff;box-shadow:0 4px 20px rgba(124,58,237,.4)}
.btn-gold{background:linear-gradient(135deg,var(--gold),#f97316);color:#000;box-shadow:0 4px 20px rgba(245,158,11,.35)}
.btn-ghost{background:transparent;color:var(--txt3);border:1px solid rgba(168,85,247,.2)}
.btn-sm{padding:10px 16px;font-size:14px}

.c{background:var(--card);border:1px solid rgba(168,85,247,.12);border-radius:var(--radius);padding:16px}
.inp{width:100%;padding:14px 16px;background:var(--bg);border:2px solid rgba(168,85,247,.2);border-radius:var(--rSm);color:#fff;font-family:var(--font);font-size:16px;outline:none;-webkit-transition:border .2s;transition:border .2s}
.inp:focus{border-color:var(--lav)}
.inp::-webkit-input-placeholder{color:var(--txt3)}

@keyframes fadeUp{from{opacity:0;-webkit-transform:translateY(20px);transform:translateY(20px)}to{opacity:1;-webkit-transform:none;transform:none}}
@keyframes shake{0%,100%{-webkit-transform:translateX(0);transform:translateX(0)}20%{-webkit-transform:translateX(-8px);transform:translateX(-8px)}40%{-webkit-transform:translateX(8px);transform:translateX(8px)}60%{-webkit-transform:translateX(-4px);transform:translateX(-4px)}80%{-webkit-transform:translateX(4px);transform:translateX(4px)}}
@keyframes bounce{0%{-webkit-transform:scale(.3);transform:scale(.3);opacity:0}50%{-webkit-transform:scale(1.08);transform:scale(1.08)}100%{-webkit-transform:scale(1);transform:scale(1);opacity:1}}
@keyframes popIn{0%{-webkit-transform:scale(0);transform:scale(0);opacity:0}60%{-webkit-transform:scale(1.15);transform:scale(1.15)}100%{-webkit-transform:scale(1);transform:scale(1);opacity:1}}
@keyframes spin{0%{-webkit-transform:rotate(0);transform:rotate(0)}100%{-webkit-transform:rotate(360deg);transform:rotate(360deg)}}
@keyframes confettiFall{0%{-webkit-transform:translateY(-10vh) rotate(0);transform:translateY(-10vh) rotate(0);opacity:1}100%{-webkit-transform:translateY(105vh) rotate(720deg);transform:translateY(105vh) rotate(720deg);opacity:0}}
@keyframes timerPulse{0%,100%{-webkit-transform:scale(1);transform:scale(1)}50%{-webkit-transform:scale(1.15);transform:scale(1.15)}}

.anim-up{-webkit-animation:fadeUp .5s ease-out both;animation:fadeUp .5s ease-out both}
.anim-bounce{-webkit-animation:bounce .6s ease-out both;animation:bounce .6s ease-out both}
.anim-pop{-webkit-animation:popIn .6s cubic-bezier(.17,.89,.32,1.28) both;animation:popIn .6s cubic-bezier(.17,.89,.32,1.28) both}
.confetti-piece{position:fixed;width:10px;height:10px;top:-10px;z-index:999;-webkit-animation:confettiFall linear forwards;animation:confettiFall linear forwards;pointer-events:none}

.pbar{height:5px;background:var(--card2);border-radius:3px;overflow:hidden;width:100%}
.pbar-fill{height:100%;border-radius:3px;-webkit-transition:width .4s ease;transition:width .4s ease;background:linear-gradient(90deg,var(--lav),var(--gold))}
.timer-bar{height:4px;background:var(--card2);border-radius:2px;overflow:hidden;width:100%;margin-top:3px}
.timer-fill{height:100%;border-radius:2px;-webkit-transition:width 1s linear;transition:width 1s linear}

.opt{background:rgba(30,14,74,.8);border:2px solid rgba(168,85,247,.2);border-radius:var(--rSm);padding:14px;cursor:pointer;-webkit-transition:all .25s;transition:all .25s;display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;gap:10px;margin-bottom:8px;-webkit-tap-highlight-color:transparent}
.opt:active{-webkit-transform:scale(.98);transform:scale(.98)}
.opt-label{width:30px;height:30px;border-radius:50%;background:var(--lavbg);display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;-webkit-justify-content:center;justify-content:center;font-weight:800;font-size:13px;color:var(--lav3);-webkit-transition:all .25s;transition:all .25s;-webkit-flex-shrink:0;flex-shrink:0}
.opt-text{font-size:15px;font-weight:600;-webkit-flex:1;flex:1;line-height:1.6}
.opt-icon{font-size:20px;font-weight:900;opacity:0;-webkit-transition:opacity .25s;transition:opacity .25s}
.opt.correct{border-color:var(--green);background:rgba(16,185,129,.1)}
.opt.correct .opt-label{background:var(--green);color:#fff}
.opt.correct .opt-icon{opacity:1;color:var(--green)}
.opt.wrong{border-color:var(--red);background:rgba(239,68,68,.06)}
.opt.wrong .opt-label{background:var(--red);color:#fff}
.opt.wrong .opt-icon{opacity:1;color:var(--red)}
.opt.dimmed{opacity:.45;pointer-events:none}

.chip{display:-webkit-inline-flex;display:inline-flex;-webkit-align-items:center;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700}
.chip-lav{background:var(--lavbg);color:var(--lav3)}
.chip-gold{background:rgba(245,158,11,.1);color:var(--gold)}

.toggle{width:48px;height:26px;border-radius:13px;background:var(--bg);border:2px solid rgba(168,85,247,.2);cursor:pointer;position:relative;-webkit-transition:all .2s;transition:all .2s;-webkit-flex-shrink:0;flex-shrink:0}
.toggle.on{background:var(--lav2)}
.toggle::after{content:'';width:20px;height:20px;border-radius:50%;background:#fff;position:absolute;top:1px;right:1px;-webkit-transition:all .2s;transition:all .2s}
.toggle.on::after{right:calc(100% - 23px)}

.topic-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.topic-card{background:var(--card);border:1px solid rgba(168,85,247,.15);border-radius:var(--radius);padding:14px;text-align:center;cursor:pointer;-webkit-transition:all .25s;transition:all .25s;-webkit-tap-highlight-color:transparent}
.topic-card:active{-webkit-transform:scale(.96);transform:scale(.96)}
.topic-icon{font-size:36px;margin-bottom:6px}
.topic-name{font-size:14px;font-weight:700;margin-bottom:2px}
.topic-desc{font-size:10px;color:var(--txt3)}

.header-bar{padding:12px 16px;display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;gap:10px;border-bottom:1px solid rgba(168,85,247,.12);background:rgba(6,1,15,.95);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);position:-webkit-sticky;position:sticky;top:0;z-index:10}
.icon-btn{width:36px;height:36px;border-radius:50%;background:var(--card);border:1px solid rgba(168,85,247,.15);display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;-webkit-justify-content:center;justify-content:center;cursor:pointer;font-size:16px;-webkit-tap-highlight-color:transparent}
.icon-btn:active{-webkit-transform:scale(.9);transform:scale(.9)}

.user-bar{display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;gap:10px;padding:12px;background:var(--card);border:1px solid rgba(168,85,247,.12);border-radius:var(--rSm);margin:0 16px}
.user-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--lav2),#4f46e5);display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;-webkit-justify-content:center;justify-content:center;font-size:18px;font-weight:900}

.age-grid{display:-webkit-flex;display:flex;gap:8px}
.age-btn{-webkit-flex:1;flex:1;padding:14px 4px;border:2px solid rgba(168,85,247,.2);border-radius:var(--rSm);background:var(--bg);text-align:center;cursor:pointer;-webkit-transition:all .2s;transition:all .2s}
.age-btn.selected{border-color:var(--lav);background:rgba(168,85,247,.12)}
.age-btn .range{font-size:20px;font-weight:900;color:var(--txt2)}
.age-btn.selected .range{color:var(--lav3)}
.age-btn .label{font-size:11px;font-weight:700;color:var(--txt3)}
.age-btn.selected .label{color:var(--lav3)}

.mode-grid{display:-webkit-flex;display:flex;gap:10px;padding:0 16px}
.mode-card{-webkit-flex:1;flex:1;padding:16px;border-radius:var(--radius);text-align:center;cursor:pointer;-webkit-transition:all .25s;transition:all .25s;border:1px solid rgba(168,85,247,.12)}
.mode-card:active{-webkit-transform:scale(.97);transform:scale(.97)}
.mode-icon{font-size:32px;margin-bottom:6px}
.mode-name{font-size:15px;font-weight:800}
.mode-desc{font-size:11px;color:var(--txt3)}

.sec-title{display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;gap:8px;padding:0 16px;font-size:15px;font-weight:700;color:var(--lav3)}
.sec-line{-webkit-flex:1;flex:1;height:1px;background:linear-gradient(90deg,var(--lav2),transparent)}

.lb-row{display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;gap:12px;padding:12px 16px;background:var(--card);border:1px solid rgba(168,85,247,.1);border-radius:var(--rSm);margin-bottom:6px}
.lb-avatar{width:32px;height:32px;border-radius:50%;display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;-webkit-justify-content:center;justify-content:center;font-weight:900;font-size:14px}
.lb-info{-webkit-flex:1;flex:1}

.hint-box{background:rgba(245,158,11,.05);border:1px solid rgba(245,158,11,.15);border-radius:var(--rSm);padding:14px;margin-top:8px}
.feedback{border-radius:var(--radius);padding:16px;text-align:center;-webkit-animation:fadeUp .3s ease-out;animation:fadeUp .3s ease-out}
.feedback.correct{background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2)}
.feedback.wrong{background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.15)}
.stats-row{display:-webkit-flex;display:flex;-webkit-justify-content:center;justify-content:center;gap:12px;margin-top:12px}
.stat-chip{display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;font-size:13px;font-weight:800}
.score-row{display:-webkit-flex;display:flex;-webkit-justify-content:space-between;justify-content:space-between;padding:4px 0;font-size:14px}
.set-row{display:-webkit-flex;display:flex;-webkit-justify-content:space-between;justify-content:space-between;-webkit-align-items:center;align-items:center;padding:10px 0}
.player-row{display:-webkit-flex;display:flex;-webkit-align-items:center;align-items:center;gap:10px;padding:10px;border-radius:10px;border:1px solid rgba(168,85,247,.1);margin-bottom:6px;background:var(--bg)}
.podium{display:-webkit-flex;display:flex;-webkit-align-items:flex-end;align-items:flex-end;-webkit-justify-content:center;justify-content:center;gap:6px;height:200px}
.podium-item{display:-webkit-flex;display:flex;-webkit-flex-direction:column;flex-direction:column;-webkit-align-items:center;align-items:center;-webkit-justify-content:flex-end;justify-content:flex-end;border-radius:16px 16px 0 0;padding:12px 8px;text-align:center}

@media(min-width:600px){.screen{max-width:480px;margin:0 auto}}
</style>
