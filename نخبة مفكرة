for(var i=0;i<300;i++){var n=ri(3,6),data=[];for(var j=0;j<n;j++)data.push(ri(10,100));var sum=0;for(var j=0;j<data.length;j++)sum+=data[j];var mean=Math.floor(sum/n);qs.push(me._q('📊','ما المتوسط الحسابي للأعداد التالية: '+data.join('، ')+' ؟',[mean+'',(mean+ri(1,5))+'',Math.max(1,mean-ri(1,5))+'',Math.max.apply(null,data)+''],0,'متوسط حسابي','اجمع كل الأعداد ثم اقسم على عددها: '+sum+' ÷ '+n))}
for(var i=0;i<200;i++){var data=[];for(var j=0;j<5;j++)data.push(ri(1,50));data.sort(function(a,b){return a-b});qs.push(me._q('📊','ما الوسيط (القيمة في المنتصف) للأعداد: '+data.join('، ')+' ؟',[data[2]+'',data[0]+'',data[4]+'',data[1]+''],0,'وسيط','رتّب الأعداد تصاعدياً ثم خذ القيمة الوسطى'))}
for(var i=0;i<200;i++){var tot=ri(6,20),fav=ri(1,tot-1);qs.push(me._q('🎲','في صندوق '+tot+' كرة، منها '+fav+' كرة حمراء. ما احتمال سحب كرة حمراء؟',[fav+'/'+tot,(tot-fav)+'/'+tot,'1/'+tot,fav+'/'+(fav+1)],0,'احتمال بسيط','الاحتمال = عدد النتائج المطلوبة ÷ عدد النتائج الكلية'))}}
if(lv===2){
for(var i=0;i<300;i++){var g1=ri(60,100),w1=ri(20,40),g2=ri(60,100),w2=100-w1,wm=Math.floor((g1*w1+g2*w2)/100);qs.push(me._q('📊','طالب حصل على '+g1+' في مادة وزنها '+w1+'% و '+g2+' في مادة وزنها '+w2+'%. ما المتوسط الموزون؟',[wm+'',Math.floor((g1+g2)/2)+'',(wm+ri(1,5))+'',g1+''],0,'متوسط موزون','المتوسط الموزون = (الدرجة×الوزن + الدرجة×الوزن) ÷ 100'))}
for(var i=0;i<300;i++){var n=ri(3,7);var f=function(x){var v=1;for(var j=2;j<=x;j++)v*=j;return v};var fact=f(n);qs.push(me._q('🔢','كم عدد الطرق الممكنة لترتيب '+n+' أشخاص في صف واحد؟ ('+n+'!)',[fact+'',(fact+ri(1,10))+'',(n*n)+'',(Math.floor(fact/2))+''],0,'تباديل','عدد التباديل = '+n+'! = '+n+' × '+(n-1)+' × ... × 1'))}
for(var i=0;i<300;i++){var n2=ri(5,10),k=ri(2,Math.min(n2-1,4));var f=function(x){var v=1;for(var j=2;j<=x;j++)v*=j;return v};var c2=f(n2)/(f(k)*f(n2-k));qs.push(me._q('🎯','كم عدد طرق اختيار '+k+' عناصر من '+n2+' عناصر بدون ترتيب؟',[c2+'',(c2+ri(1,10))+'',(n2*k)+'',Math.max(1,c2-ri(1,10))+''],0,'توافيق','التوافيق = ن! ÷ (ك! × (ن-ك)!)'))}}
if(lv===3){
var dists=[['كم نسبة البيانات ضمن انحراف معياري واحد من المتوسط في التوزيع الطبيعي؟','68%','95%','50%','99%'],['كم نسبة البيانات ضمن انحرافين معياريين من المتوسط؟','95%','68%','99%','75%'],['كم نسبة البيانات ضمن 3 انحرافات معيارية من المتوسط؟','99.7%','95%','68%','100%'],['ما شكل منحنى التوزيع الطبيعي؟','جرسي متماثل حول المتوسط','خط مستقيم صاعد','خط تصاعدي منحنٍ','مثلث متساوي الأضلاع'],['ما قيمة معامل الارتباط الطردي التام؟','+1','-1','0','0.5'],['ما قيمة معامل الارتباط العكسي التام؟','-1','+1','0','-0.5']];
for(var d=0;d<dists.length;d++){for(var k=0;k<30;k++)qs.push(me._q('📊',dists[d][0],[dists[d][1],dists[d][2],dists[d][3],dists[d][4]],0,'توزيع طبيعي','تذكّر القاعدة التجريبية 68-95-99.7'))}
for(var i=0;i<300;i++){var x=ri(50,100),mean=ri(60,80),sd=ri(5,15),z=Math.round((x-mean)/sd*10)/10;qs.push(me._q('📊','في توزيع طبيعي متوسطه '+mean+' وانحرافه المعياري '+sd+'. ما الدرجة المعيارية Z للقيمة '+x+'؟',['Z ≈ '+z,'Z ≈ '+(z+0.5),'Z ≈ '+(z-0.5),'Z ≈ '+(x-mean)],0,'درجة معيارية','Z = (القيمة - المتوسط) ÷ الانحراف المعياري'))}
for(var i=0;i<300;i++){var alpha=[0.01,0.05,0.10][ri(0,2)],pv=ri(1,15)/100,rej=pv<alpha;qs.push(me._q('🔬','في اختبار فرضيات مستوى الدلالة α = '+alpha+' والقيمة الاحتمالية p = '+pv+'. ما القرار الإحصائي؟',[rej?'رفض الفرضية الصفرية':'عدم رفض الفرضية الصفرية',rej?'عدم رفض الفرضية الصفرية':'رفض الفرضية الصفرية','قبول الفرضية البديلة دائماً','إعادة التجربة'],0,'اختبار فرضيات','إذا كانت p أقل من α نرفض الفرضية الصفرية'))}}
return shuffle(qs)},

flight:function(lv){var qs=[];var me=this;
var core=[['كيف يولّد جناح الطائرة قوة الرفع التي تجعلها تطير؟','الهواء يتحرك أسرع فوق الجناح فيقل الضغط','الجناح مملوء بغاز خفيف يرفعه','المحرك يدفع الجناح للأعلى مباشرة','الهواء تحت الجناح يسخن ويتمدد'],['ما هي القوى الأربع الرئيسية التي تؤثر على الطائرة أثناء الطيران؟','الرفع والوزن والدفع والمقاومة','الرفع والجاذبية والاحتكاك والطرد','الدفع والسحب والمغناطيسية والضغط','الحرارة والضغط والكثافة والسرعة'],['ما المقصود بالتوقف الهوائي (Stall) في الطيران؟','فقدان مفاجئ لقوة الرفع عن الجناح','زيادة كبيرة في سرعة الطائرة','انثناء وكسر في جناح الطائرة','ارتفاع شديد في حرارة المحرك'],['كيف يستطيع الصاروخ التحرك في الفضاء حيث لا يوجد هواء؟','يدفع غازات للخلف فيتقدم للأمام (قانون نيوتن الثالث)','يدفع الهواء المتبقي حوله','يستخدم قوة مغناطيسية','يعتمد على الأشعة الشمسية'],['من هو أول إنسان سافر إلى الفضاء في التاريخ؟','يوري غاغارين عام 1961','نيل آرمسترونغ عام 1969','جون غلين عام 1962','ألان شيبرد عام 1961'],['من هو أول إنسان مشى على سطح القمر؟','نيل آرمسترونغ عام 1969','باز ألدرين عام 1969','يوري غاغارين عام 1961','مايكل كولينز عام 1969'],['ما هي سرعة الإفلات اللازمة للخروج من جاذبية الأرض؟','حوالي 11.2 كم في الثانية','حوالي 1 كم في الثانية','حوالي 100 كم في الثانية','حوالي 343 متر في الثانية'],['في أي عام نجح الأخوان رايت في أول رحلة طيران بطائرة؟','عام 1903','عام 1910','عام 1895','عام 1920'],['لماذا يكون الإقلاع أصعب في الأجواء الحارة جداً؟','لأن الهواء الساخن أقل كثافة فيقل الرفع','لأن إطارات الطائرة تلتصق بالمدرج','لأن الوقود يتبخر بسرعة','لأن المحرك يسخن ويضعف'],['لماذا تطير معظم الطائرات التجارية على ارتفاع 10 كم تقريباً؟','الهواء أقل كثافة فتقل المقاومة ويتوفر الوقود','لتجنب اصطدام الطيور','بسبب قوانين الطيران الدولية','لأن المحركات تحتاج البرودة']];
var mult=lv===1?10:lv===2?12:16;for(var c=0;c<core.length;c++){for(var k=0;k<mult;k++)qs.push(me._q('✈️',core[c][0],[core[c][1],core[c][2],core[c][3],core[c][4]],0,'معلومات طيران','اقرأ الخيارات بتمعّن واختر الأكثر منطقية'))}
for(var i=0;i<300;i++){var spd=ri(200,900),t=ri(1,8),d=spd*t;qs.push(me._q('✈️','طائرة تطير بسرعة ثابتة '+spd+' كم/ساعة. كم كيلومتراً تقطع في '+t+' ساعات؟',[d+' كم',(d+ri(50,200))+' كم',(spd+t)+' كم',(d-spd)+' كم'],0,'مسافة طيران','المسافة = السرعة × الزمن'))}
for(var i=0;i<200;i++){var ft=ri(10,45)*1000,m=Math.round(ft*0.3048);qs.push(me._q('📏','طائرة تطير على ارتفاع '+ft+' قدم. كم يساوي هذا بالمتر تقريباً؟ (1 قدم ≈ 0.3 متر)',['≈ '+m+' متر','≈ '+(m+ri(100,500))+' متر','≈ '+Math.max(100,m-ri(100,300))+' متر','≈ '+ft+' متر'],0,'تحويل وحدات','اضرب عدد الأقدام في 0.3 تقريباً'))}
if(lv>=2){for(var i=0;i<200;i++){var alt=ri(1,15)*1000,temp=15-Math.round(alt*6.5/1000);qs.push(me._q('🌡️','على ارتفاع '+alt+' متر من سطح البحر، كم تكون درجة الحرارة تقريباً؟ (تنخفض 6.5° لكل كم)',['≈ '+temp+' درجة مئوية','≈ '+(temp+ri(3,10))+' درجة مئوية','≈ '+(temp-ri(3,10))+' درجة مئوية','≈ 15 درجة مئوية'],0,'غلاف جوي','الحرارة = 15 - (الارتفاع بالكم × 6.5)'))}}
if(lv===3){for(var i=0;i<200;i++){var m2=ri(1,10)*1000,h=ri(100,10000),pe=m2*10*h;qs.push(me._q('🚀','صاروخ كتلته '+m2+' كجم يرتفع إلى '+h+' متر. ما طاقة وضعه؟ (الجاذبية = 10)',[pe+' جول',(m2*h)+' جول',(pe+ri(1000,5000))+' جول',(m2*10)+' جول'],0,'طاقة في الفضاء','طاقة الوضع = الكتلة × الجاذبية × الارتفاع'))}}
return shuffle(qs)},

iq:function(lv){var qs=[];var me=this;
for(var i=0;i<250;i++){var a=ri(1,20),b=ri(2,10);var seq=[];for(var j=0;j<5;j++)seq.push(a+b*j);var next=a+b*5;qs.push(me._q('🧩','ما العدد التالي في هذا النمط: '+seq.join('، ')+' ، ___ ؟',[next+'',(next+b)+'',(next-1)+'',(next+ri(1,4))+''],0,'أنماط عددية','لاحظ الفرق بين كل عدد والذي يليه = '+b))}
for(var i=0;i<150;i++){var a=ri(1,5),r=ri(2,3);var seq=[];var v=a;for(var j=0;j<4;j++){seq.push(v);v*=r}if(v<10000)qs.push(me._q('🧩','ما العدد التالي في هذا النمط: '+seq.join('، ')+' ، ___ ؟',[v+'',(v+ri(1,10))+'',(seq[3]+seq[2])+'',(Math.floor(v/2))+''],0,'أنماط هندسية','كل عدد يساوي العدد السابق مضروباً في '+r))}
var odds=[['تفاحة، موز، جزر، عنب — أي عنصر لا ينتمي للمجموعة؟','جزر (خضار وليس فاكهة)','تفاحة','موز','عنب'],['مربع، مستطيل، دائرة، معين — أي شكل يختلف عن البقية؟','الدائرة (ليس لها أضلاع)','المربع','المستطيل','المعين'],['كلب، قطة، سمكة، أرنب — أي حيوان يختلف عن البقية؟','السمكة (ليست من الثدييات)','الكلب','القطة','الأرنب'],['أحمر، أزرق، حار، أخضر — أي كلمة لا تنتمي؟','حار (ليس لوناً بل صفة حرارة)','أحمر','أزرق','أخضر'],['كرسي، طاولة، باب، سرير — أي عنصر يختلف؟','الباب (ليس قطعة أثاث)','الكرسي','الطاولة','السرير'],['الأرض، المريخ، القمر، المشتري — أيها يختلف؟','القمر (تابع وليس كوكباً)','الأرض','المريخ','المشتري']];
for(var o=0;o<odds.length;o++){for(var k=0;k<25;k++)qs.push(me._q('🤔',odds[o][0],[odds[o][1],odds[o][2],odds[o][3],odds[o][4]],0,'الشاذ','ابحث عن القاسم المشترك بين ثلاثة عناصر والعنصر المختلف'))}
for(var i=0;i<200;i++){var a=ri(2,15),b=ri(2,15),s=a+b,p=a*b;qs.push(me._q('🧠','عددان مجموعهما '+s+' وحاصل ضربهما '+p+'. ما هما؟',[a+' و '+b,(a+1)+' و '+(b-1),s+' و 0',(Math.floor(p/2))+' و 2'],0,'منطق رياضي','جرّب أزواج الأعداد التي مجموعها '+s+' واحسب ضربها'))}
for(var i=0;i<200;i++){var age1=ri(25,50),diff=ri(20,30),age2=age1-diff;qs.push(me._q('🧠','عمر أب '+age1+' سنة والفرق بينه وبين ابنه '+diff+' سنة. كم عمر الابن؟',[age2+' سنة',(age2+ri(1,5))+' سنة',(age1+diff)+' سنة',diff+' سنة'],0,'ألغاز عمرية','عمر الابن = عمر الأب - فرق العمر'))}
for(var i=0;i<200;i++){var a=ri(3,20),b=ri(3,20),c=a*b;qs.push(me._q('🧩','أكمل الفراغ: '+a+' × ___ = '+c+'. ما العدد الناقص؟',[b+'',(b+1)+'',(b-1)+'',(Math.floor(c/2))+''],0,'إكمال','اقسم الناتج '+c+' على '+a+' لتجد العدد المفقود'))}
for(var i=0;i<150;i++){var stH=ri(1,12),dur=ri(1,6),end=(stH+dur)>12?(stH+dur-12):(stH+dur);qs.push(me._q('🕐','إذا كانت الساعة الآن '+stH+' وانتظرت '+dur+' ساعات، كم ستكون الساعة؟',[end+'',(end+1>12?1:end+1)+'',(stH+dur)+'',Math.max(1,end-1)+''],0,'ألغاز الساعة','أضف '+dur+' إلى '+stH+' (إذا تجاوزت 12 اطرح 12)'))}
return shuffle(qs)}
};

